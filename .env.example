# 楽天市場API（無料）
# https://webservice.rakuten.co.jp/ でアプリ登録後に取得
RAKUTEN_APP_ID=your_rakuten_app_id

# オプション: Yahoo!ショッピングAPI（無料）
# https://developer.yahoo.co.jp/webapi/shopping/
YAHOO_CLIENT_ID=your_yahoo_client_id

# オプション: Amazon Product Advertising API（公式・審査あり）
# https://affiliate.amazon.co.jp/assoc_credentials/home
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=your_amazon_partner_tag

# オプション: RapidAPI 経由の Real-Time Amazon Data（PA-API の代替）
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
RAPIDAPI_KEY=your_rapidapi_key

# オプション: Keepa API（Amazon 価格推移分析）
# https://keepa.com/#!api
KEEPA_API_KEY=your_keepa_key
